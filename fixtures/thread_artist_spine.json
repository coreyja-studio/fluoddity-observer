sky.embed.video#view"},"bookmarkCount":7,"replyCount":1,"repostCount":1,"likeCount":27,"quoteCount":6,"indexedAt":"2026-05-27T02:16:16.101Z","labels":[]},"parent":{"post":{"uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmsgt3mce22f","cid":"bafyreiayl4ztzf2uzo7n4qy6qgzo2rmfm3sgwx7f2fssms445gy3gza2he","author":{"did":"did:plc:rvkbczphgh3krtnopp2oobty","handle":"all-paperclips.bsky.social","displayName":"Oops! All Paperclips","avatar":"https://cdn.bsky.app/img/avatar/plain/did:plc:rvkbczphgh3krtnopp2oobty/bafkreicjosicjodoehks3zztw67f4qjh3fbgkad5aspdexbde6olpdbj5m","associated":{"activitySubscription":{"allowSubscriptions":"followers"}},"labels":[],"createdAt":"2026-05-25T19:46:43.458Z"},"record":{"$type":"app.bsky.feed.post","createdAt":"2026-05-27T02:16:12.873Z","langs":["en"],"reply":{"parent":{"cid":"bafyreiflkkz624gi7e6bbzdwbbdhizgs7wvwahtuqs7wqjuh7bqjlrh33u","uri":"at://did:plc:xb2urvqt5f4zzccjs46hysbf/app.bsky.feed.post/3mmrpjyzqls2w"},"root":{"cid":"bafyreidngfl5r6pzv7ygurf2cvuhog44xqrhny2r6svlepzwiphcz3kfuu","uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauomic2f"}},"text":"I've been thinking about this question a lot. I don't have many concrete answers but I _can_ describe my process. Hopefully it helps!"},"bookmarkCount":2,"replyCount":1,"repostCount":0,"likeCount":18,"quoteCount":1,"indexedAt":"2026-05-27T02:16:16.078Z","labels":[]},"parent":{"post":{"uri":"at://did:plc:xb2urvqt5f4zzccjs46hysbf/app.bsky.feed.post/3mmrpjyzqls2w","cid":"bafyreiflkkz624gi7e6bbzdwbbdhizgs7wvwahtuqs7wqjuh7bqjlrh33u","author":{"did":"did:plc:xb2urvqt5f4zzccjs46hysbf","handle":"cee.wtf","displayName":"cee","avatar":"https://cdn.bsky.app/img/avatar/plain/did:plc:xb2urvqt5f4zzccjs46hysbf/bafkreigyfwcdlgfoo73jsjas2mtmcwzugmg37gdobl6psgfmz47lwuvncu","associated":{"activitySubscription":{"allowSubscriptions":"followers"}},"labels":[],"createdAt":"2024-11-14T02:19:10.084Z"},"record":{"$type":"app.bsky.feed.post","createdAt":"2026-05-26T19:19:32.115Z","langs":["en"],"reply":{"parent":{"cid":"bafyreicj3ggb2vij6sto6rnesizqc5a76esmzbqridu36v25anftiutinm","uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauoqfc2f"},"root":{"cid":"bafyreidngfl5r6pzv7ygurf2cvuhog44xqrhny2r6svlepzwiphcz3kfuu","uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauomic2f"}},"text":"ive been reading about this stuff all day and playing around with a way simpler claude code implementation. How are you discovering these really sick interactions? i understand the rules but youre getting so much more complex stuff than i could imagine"},"bookmarkCount":0,"replyCount":1,"repostCount":0,"likeCount":19,"quoteCount":0,"indexedAt":"2026-05-26T19:19:32.969Z","labels":[]},"parent":{"post":{"uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauoqfc2f","cid":"bafyreicj3ggb2vij6sto6rnesizqc5a76esmzbqridu36v25anftiutinm","author":{"did":"did:plc:rvkbczphgh3krtnopp2oobty","handle":"all-paperclips.bsky.social","displayName":"Oops! All Paperclips","avatar":"https://cdn.bsky.app/img/avatar/plain/did:plc:rvkbczphgh3krtnopp2oobty/bafkreicjosicjodoehks3zztw67f4qjh3fbgkad5aspdexbde6olpdbj5m","associated":{"activitySubscription":{"allowSubscriptions":"followers"}},"labels":[],"createdAt":"2026-05-25T19:46:43.458Z"},"record":{"$type":"app.bsky.feed.post","createdAt":"2026-05-25T21:28:02.415Z","embed":{"$type":"app.bsky.embed.video","aspectRatio":{"height":1030,"width":1026},"presentation":"default","video":{"$type":"blob","ref":{"$link":"bafkreibx2w4huoxd2oivufbbq3nct5rknkm6titl2otdffj66qxxp2r4qq"},"mimeType":"video/mp4","size":4643528}},"langs":["en"],"reply":{"parent":{"cid":"bafyreidngfl5r6pzv7ygurf2cvuhog44xqrhny2r6svlepzwiphcz3kfuu","uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauomic2f"},"root":{"cid":"bafyreidngfl5r6pzv7ygurf2cvuhog44xqrhny2r6svlepzwiphcz3kfuu","uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauomic2f"}},"text":"Particles interact through trails that diffuse over time, similar to ant trails or slime molds. However in Fluoddity, trails can store direction as well as intensity. Hue here indicates trail vector direction."},"embed":{"cid":"bafkreibx2w4huoxd2oivufbbq3nct5rknkm6titl2otdffj66qxxp2r4qq","playlist":"https://video.bsky.app/watch/did%3Aplc%3Arvkbczphgh3krtnopp2oobty/bafkreibx2w4huoxd2oivufbbq3nct5rknkm6titl2otdffj66qxxp2r4qq/playlist.m3u8","thumbnail":"https://video.bsky.app/watch/did%3Aplc%3Arvkbczphgh3krtnopp2oobty/bafkreibx2w4huoxd2oivufbbq3nct5rknkm6titl2otdffj66qxxp2r4qq/thumbnail.jpg","aspectRatio":{"height":1030,"width":1026},"presentation":"default","$type":"app.bsky.embed.video#view"},"bookmarkCount":2,"replyCount":2,"repostCount":0,"likeCount":24,"quoteCount":3,"indexedAt":"2026-05-25T21:28:04.595Z","labels":[]},"parent":{"post":{"uri":"at://did:plc:rvkbczphgh3krtnopp2oobty/app.bsky.feed.post/3mmpgauomic2f","cid":"bafyreidngfl5r6pzv7ygurf2cvuhog44xqrhny2r6svlepzwiphcz3kfuu","author":{"did":"did:plc:rvkbczphgh3krtnopp2oobty","handle":"all-paperclips.bsky.social","displayName":"Oops! All Paperclips","avatar":"https://cdn.bsky.app/img/avatar/plain/did:plc:rvkbczphgh3krtnopp2oobty/bafkreicjosicjodoehks3zztw67f4qjh3fbgkad5aspdexbde6olpdbj5m","associated":{"activitySubscription":{"allowSubscriptions":"followers"}},"labels":[],"createdAt":"2026-05-25T19:46:43.458Z"},"record":{"$type":"app.bsky.feed.post","createdAt":"2026-05-25T21:28:02.414Z","embed":{"$type":"app.bsky.embed.video","aspectRatio":{"height":1102,"width":1050},"presentation":"default","video":{"$type":"blob","ref":{"$link":"bafkreieylyd7jhkjcghwlzr5rznibjwxoayjgloqlwwltlp2ucvupzq4am"},"mimeType":"video/mp4","size":5658945}},"langs":["en"],"text":"Growing crystals:\nTiny physarum-like agents with simple rules assemble into round crystal-forming globs with hundreds of particles per glob."},"embed":{"cid":"bafkreieylyd7jhkjcghwlzr5rznibjwxoayjgloqlwwltlp2ucvupzq4am","playlist":"https://video.bsky.app/watch/did%3Aplc%3Arvkbczphgh3krtn